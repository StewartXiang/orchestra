{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestra.io/schema/v1/agent-profile.schema.json",
  "title": "AgentProfileSet",
  "description": "Agent profile 配置集合（config/profiles.yaml）。定义集群中具体存在的 Agent 实例。",
  "type": "object",
  "required": ["apiVersion", "kind", "profiles"],
  "unevaluatedProperties": false,
  "properties": {
    "apiVersion": {"type": "string", "const": "orchestra.io/v1"},
    "kind": {"type": "string", "const": "AgentProfileSet"},
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9-]{0,62}$": {"$ref": "#/$defs/Profile"}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "Profile": {
      "type": "object",
      "required": ["role", "mcpEndpoint"],
      "unevaluatedProperties": false,
      "properties": {
        "role": {"type": "string", "enum": ["developer", "tester", "designer", "ci_engineer", "chat", "standby"]},
        "capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "mcpEndpoint": {"type": "string", "format": "uri"},
        "model": {"type": "string"},
        "tools": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "labels": {"type": "object", "additionalProperties": {"type": "string"}},
        "taskQueue": {"type": "string"},
        "maxConcurrency": {"type": "integer", "minimum": 1, "default": 1},
        "description": {"type": "string"}
      }
    }
  }
}
